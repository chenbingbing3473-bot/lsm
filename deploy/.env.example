# 复制为 deploy/.env 后修改（deploy.sh 可自动生成）

# 浏览器访问地址：http://公网IP 或 https://你的域名.com（无末尾斜杠）
PUBLIC_URL=http://127.0.0.1

# 对外 HTTP 端口（默认 80；若 80 被占用可改为 8080）
HTTP_PORT=80

# JWT 密钥（deploy.sh 首次运行会自动生成，生产请保留并备份）
JWT_SECRET=

# 通义千问 / DashScope（上传识图菜谱，可选）
DASHSCOPE_API_KEY=

# 首次部署是否写入演示数据（true / false）
RUN_SEED=true

# 短信验证码开发模式（生产接阿里云短信后改为 false）
SMS_DEV_MODE=true

JWT_EXPIRES_IN=7d
QWEN_VL_MODEL=qwen-vl-plus

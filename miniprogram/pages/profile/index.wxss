.login-prompt {
  text-align: center;
  padding: 80rpx 48rpx;
}

.prompt-title {
  font-size: 40rpx;
  font-weight: 700;
  display: block;
}

.prompt-desc {
  font-size: 26rpx;
  color: var(--on-surface-variant);
  display: block;
  margin: 24rpx 0 48rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-top: 24rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: var(--surface-container);
}

.name {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
}

.phone {
  font-size: 24rpx;
  color: var(--on-surface-variant);
}

.stat-card {
  text-align: center;
}

.stat-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--outline);
  text-transform: uppercase;
  display: block;
}

.stat-val {
  font-size: 48rpx;
  font-weight: 800;
  display: block;
  margin-top: 8rpx;
}

.block-title {
  font-size: 28rpx;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--primary);
  display: block;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--outline);
  display: block;
  margin-bottom: 8rpx;
}

.field-input {
  background: var(--surface-container);
  border-radius: 24rpx;
  padding: 24rpx;
}

.textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--surface-container);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.logout {
  color: var(--primary) !important;
  border-color: var(--primary) !important;
}

.lang-switch {
  text-align: center;
  margin-top: 48rpx;
  color: var(--secondary);
  font-weight: 700;
  font-size: 26rpx;
}

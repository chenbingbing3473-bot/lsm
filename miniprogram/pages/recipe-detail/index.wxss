.detail-page {
  min-height: 100vh;
  background: var(--surface);
  padding-bottom: 80rpx;
}

.hero-img {
  width: 100%;
  height: 560rpx;
}

.back-btn {
  position: fixed;
  top: 80rpx;
  left: 32rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(254, 253, 241, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  z-index: 10;
}

.content {
  padding: 48rpx;
  margin-top: -80rpx;
  position: relative;
  background: var(--surface);
  border-radius: 48rpx 48rpx 0 0;
}

.title {
  font-size: 48rpx;
  font-weight: 900;
  flex: 1;
  line-height: 1.2;
}

.kcal-box {
  text-align: right;
}

.kcal-num {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--primary);
  display: block;
}

.kcal-label {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--outline);
}

.section {
  margin-top: 48rpx;
}

.section-label {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--primary);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  display: block;
  margin-bottom: 16rpx;
}

.taste {
  font-style: italic;
  color: var(--on-surface-variant);
  line-height: 1.6;
}

.actions {
  margin-top: 32rpx;
}

.flex-1 {
  width: 100%;
}

.comment {
  background: var(--surface-container-low);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.comment-user {
  font-weight: 700;
  font-size: 24rpx;
  display: block;
}

.comment-text {
  font-size: 26rpx;
  color: var(--on-surface-variant);
}

.comment-input {
  background: var(--surface-container);
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 16rpx 0;
}

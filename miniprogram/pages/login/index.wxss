.login-page {
  padding-top: 80rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 48rpx;
}

.form {
  padding: 48rpx;
}

.input {
  background: var(--surface-container);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.code-row {
  display: flex;
  gap: 16rpx;
}

.code-input {
  flex: 1;
  margin-bottom: 0;
}

.code-btn {
  background: var(--on-surface) !important;
  color: var(--surface) !important;
  font-size: 24rpx !important;
  border-radius: 32rpx !important;
  padding: 0 24rpx !important;
  white-space: nowrap;
}

.dev-hint {
  display: block;
  font-size: 24rpx;
  color: var(--primary);
  margin: 16rpx 0;
}

.login-btn {
  margin-top: 32rpx;
}

.hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--on-surface-variant);
  margin-top: 32rpx;
}

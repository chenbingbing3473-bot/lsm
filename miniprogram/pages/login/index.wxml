<view class="page login-page">
  <text class="eyebrow">KINETIC</text>
  <text class="title">{{lang === 'zh' ? '手机号登录' : 'Phone Login'}}</text>

  <view class="card form">
    <input class="input" type="number" maxlength="11" placeholder="手机号" value="{{phone}}" bindinput="onPhone" />
    <view class="code-row">
      <input class="input code-input" type="number" maxlength="6" placeholder="验证码" value="{{code}}" bindinput="onCode" />
      <button class="code-btn" loading="{{sending}}" bindtap="sendCode">获取验证码</button>
    </view>
    <text wx:if="{{devCode}}" class="dev-hint">开发验证码: {{devCode}}</text>
    <button class="btn-primary login-btn" loading="{{loading}}" bindtap="login">登录</button>
    <text class="hint">演示账号 13800138000 / 密码登录请用 Web 版</text>
  </view>
</view>

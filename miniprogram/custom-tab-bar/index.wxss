.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fefdf1;
  border-top: 2rpx solid #e7ebcf;
  display: flex;
  flex-direction: row;
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #7e836b;
}

.tab-item.active {
  color: #ae3c4c;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1.2;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

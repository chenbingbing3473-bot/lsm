<cover-view class="tab-bar">
  <cover-view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <cover-view class="tab-icon">{{item.icon}}</cover-view>
    <cover-view class="tab-text">{{lang === 'zh' ? item.text : item.textEn}}</cover-view>
  </cover-view>
</cover-view>
